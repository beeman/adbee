{
  "bin": {
    "adbee": "dist/cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/beeman/adbee/issues"
  },
  "dependencies": {
    "@crustjs/core": "^0.0.15",
    "@crustjs/plugins": "^0.0.20",
    "@crustjs/prompts": "^0.0.10"
  },
  "description": "Convenience CLI for Android Debug Bridge (adb).",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "^2.29.8",
    "@intellectronica/ruler": "^0.3.34",
    "@types/bun": "1.3.11",
    "pkg-pr-new": "^0.0.62",
    "publint": "^0.3.16",
    "tsdown": "^0.20.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/beeman/adbee#readme",
  "keywords": [
    "adb",
    "android",
    "bun",
    "cli"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "name": "adbee",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeman/adbee.git"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check-types": "tsc -b --noEmit",
    "ci": "bun run build && bun run lint && bun run check-types && bun test",
    "dev": "bun run src/cli.ts",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "version": "changeset version && bun lint:fix"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "0.1.1"
}
